# Acceso público (Cliente y Servidor)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=publishable_key

# Acceso privado (Solo Servidor)
# Úsala solo si necesitas crear scripts que ignoren el RLS
SUPABASE_SERVICE_ROLE_KEY=secret_key

# Kapso API
KAPSO_API_KEY=tu_api_key_de_kapso

# Secreto para validar que los webhooks vienen de Kapso
KAPSO_WEBHOOK_SECRET=una_clave_larga_y_segura_2026

# URL de tu aplicación (para redirecciones en el flujo de WhatsApp)
NEXT_PUBLIC_APP_URL=http://localhost:3000 o la URL de tu aplicación en producción
